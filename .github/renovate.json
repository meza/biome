{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>stateshifters/renovate-common", "customManagers:biomeVersions"],
  "packageRules": [
    {
      "matchPackageNames": ["@biomejs/biome"],
      "commitMessagePrefix": "fix",
      "postUpgradeTasks": {
        "commands": ["pnpm exec biome migrate --write"]
      }
    }
  ]
}
